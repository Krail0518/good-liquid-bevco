# ============================================================
# Edge function secrets — copy this file to supabase/secrets.env
# and fill in your real values. The deploy script reads from
# supabase/secrets.env (which is gitignored).
# ============================================================
# Format: KEY=value (no quotes, no spaces around =)
# Lines starting with # are comments. Empty values are skipped.
# ============================================================

# ─── Stripe ──────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use the SECRET key (sk_live_… or sk_test_… for sandbox)
STRIPE_SECRET_KEY=

# ─── Twilio (SMS) ────────────────────────────────────────
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─── Dropbox Sign (formerly HelloSign) ───────────────────
# Get from: https://app.hellosign.com/home/myAccount#api
HELLOSIGN_API_KEY=
# Set to "1" while testing (no real signatures, free), "0" for production
HELLOSIGN_TEST_MODE=1

# ─── QuickBooks Online (Intuit) ──────────────────────────
# Create an app at: https://developer.intuit.com/app/developer/dashboard
# Set the OAuth redirect URI in the Intuit app to:
#   https://<your-project-ref>.supabase.co/functions/v1/qbo-callback
INTUIT_CLIENT_ID=
INTUIT_CLIENT_SECRET=
INTUIT_REDIRECT_URI=
# "sandbox" for testing, "production" for live data
INTUIT_ENV=sandbox

# ============================================================
# Notes
# ============================================================
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected
# by the Supabase runtime — you do NOT need to set them here.
# ============================================================
